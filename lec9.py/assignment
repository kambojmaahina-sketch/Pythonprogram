'''print 1-10'''
i=1
while i<=10:
    print(f"{i}")
    i+=1

'''print 10-1'''
i=10
while i>=1:
    print(f"{i}")
    i-=1

'''print squares-1,4,9,16...100'''
i=1
while i<=10:
    result=i**2
    print(f"{result}")
    i+=1

'''powers of 2'''
i=1
while i<=9:
    result=2**i
    print(f"{result}")
    i+=1

'''table of 5'''
i=1
while i<=10:
    result=5*i
    print(f"5*{i}={result}")
    i+=1

