'''
Nested ifelse--syntax
if condition:
    statement1
    if condition:
    statement2
    statement3
    else:
    statement4
    statement5
else:
    if condition:
    statement6
    statement7
    else:
    statement8
    statement9
'''

age=int(input("enter age:"))
if age>=18:
   if age<=45:
       print("You are eligible for LIC.")
   else:
       print("You are not eligible for LIC.")
else:
    print("You are not eligible for LIC.")


