#--basic method
a=[4,6,8,2,7,22]
b=[]
for i in a:
    b.append(i**2)
print(b)


#--via list comprehension
a=[4,6,8,2,7,22]
b=[i**2 for i in a]
print(b)


#--more than one variable
a=[4,6,8,2,7,22]
b=[i**2 for i in a]
c=[i for i in a if i%2==0]
d=[i for i in a if i%2==0 and i%5==0]
e=[f"{i}:even" if i%2==0 else f"{i}:odd" for i in a]
print(e)
